# DB
DB_HOST=localhost
DB_PORT=5433
DB_NAME=smartfarm
DB_USER=smartfarm
DB_PASSWORD=your-db-password-here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT (setup-mqtt-passwd.sh 실행 후 동일한 값을 사용)
MQTT_BROKER_URL=tcp://localhost:1884
MQTT_CLIENT_ID=smartfarm-backend
MQTT_USERNAME=smartfarm-backend
MQTT_PASSWORD=your-mqtt-password-here

# JWT (최소 32자 이상의 랜덤 문자열)
JWT_SECRET=your-256-bit-secret-here-must-be-at-least-32-characters-long
JWT_EXPIRATION_MS=86400000

# Control
CONTROL_MODE=rule
